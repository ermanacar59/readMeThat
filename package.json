{
  "name": "doc-to-speech-local",
  "private": true,
  "version": "0.1.0",
  "description": "Local-first modular document-to-speech monorepo MVP",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "concurrently -n api,web \"npm run dev -w @doc2speech/api\" \"npm run dev -w @doc2speech/web\"",
    "build": "npm run build -ws --if-present",
    "typecheck": "npm run typecheck -ws --if-present",
    "translation:check": "node scripts/check-libretranslate.mjs"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "concurrently": "^9.0.1",
    "typescript": "^5.6.3"
  }
}
